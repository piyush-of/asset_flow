<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_flow_maintenance_kanban" model="ir.ui.view">
        <field name="name">asset_flow.maintenance.kanban</field>
        <field name="model">asset_flow.maintenance</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage" class="o_kanban_small_column" records_draggable="true">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="requested_by"/>
                <field name="stage"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record card shadow-sm mb-2">
                            <div class="oe_kanban_details d-flex flex-column justify-content-between">
                                <strong class="o_kanban_record_title text-primary"><field name="name"/></strong>
                                <div class="text-muted mt-1">
                                    <span>Asset: </span><strong><field name="asset_id"/></strong>
                                </div>
                                <div class="text-muted small mt-1">
                                    <span>Reporter: </span><field name="requested_by"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_asset_flow_maintenance_tree" model="ir.ui.view">
        <field name="name">asset_flow.maintenance.tree</field>
        <field name="model">asset_flow.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Requests">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="requested_by"/>
                <field name="stage" widget="badge" decoration-danger="stage == 'draft'" decoration-warning="stage == 'progress'" decoration-success="stage == 'fixed'"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_flow_maintenance_form" model="ir.ui.view">
        <field name="name">asset_flow.maintenance.form</field>
        <field name="model">asset_flow.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Request">
                <header>
                    <field name="stage" widget="statusbar" statusbar_visible="draft,progress,fixed" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="asset_id"/>
                        </group>
                        <group>
                            <field name="requested_by"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_asset_flow_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">asset_flow.maintenance</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>