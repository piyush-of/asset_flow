<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_flow_booking_tree" model="ir.ui.view">
        <field name="name">asset_flow.booking.tree</field>
        <field name="model">asset_flow.booking</field>
        <field name="arch" type="xml">
            <tree string="Resource Bookings">
                <field name="asset_id"/>
                <field name="user_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="state" widget="badge" decoration-info="state == 'upcoming'" decoration-success="state == 'ongoing'" decoration-muted="state == 'completed'" decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_flow_booking_calendar" model="ir.ui.view">
        <field name="name">asset_flow.booking.calendar</field>
        <field name="model">asset_flow.booking</field>
        <field name="arch" type="xml">
            <calendar string="Booking Schedule" date_start="start_time" date_stop="end_time" color="asset_id" quick_create="false">
                <field name="asset_id"/>
                <field name="user_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_asset_flow_booking_form" model="ir.ui.view">
        <field name="name">asset_flow.booking.form</field>
        <field name="model">asset_flow.booking</field>
        <field name="arch" type="xml">
            <form string="Resource Booking">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="upcoming,ongoing,completed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="start_time"/>
                            <field name="end_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asset_flow_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">asset_flow.booking</field>
        <field name="view_mode">tree,calendar,form</field>
    </record>
</odoo>