    <menuitem id="menu_asset_flow_configuration"
              name="Configuration"
              parent="menu_asset_flow_root"
              sequence="100"/>

    <menuitem id="menu_asset_flow_category"
              name="Categories"
              parent="menu_asset_flow_configuration"
              action="action_asset_flow_category"
              sequence="10"/>
    <record id="action_asset_flow_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">asset_flow.maintenance</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
    
    <menuitem id="menu_asset_flow_maintenance" 
