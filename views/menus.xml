<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <menuitem id="menu_asset_flow_root"
              name="AssetFlow"
              sequence="10"
              web_icon="asset_flow,static/description/icon.png"/>

    <menuitem id="menu_asset_flow_assets"
              name="Assets"
              parent="menu_asset_flow_root"
              sequence="10"/>

    <menuitem id="menu_asset_flow_asset_all"
              name="All Assets"
              parent="menu_asset_flow_assets"
