              sequence="10"/>

    <menuitem id="menu_asset_flow_allocation_all"
              name="Allocations"
              parent="menu_asset_flow_assets"
              action="action_asset_flow_allocation"
              sequence="20"/>

    <menuitem id="menu_asset_flow_booking_all"
              name="Bookings"
              parent="menu_asset_flow_assets"
              action="action_asset_flow_booking"
